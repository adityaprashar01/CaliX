# === .env.local ===

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Project Settings → Database → Connection string)
DATABASE_URL=               # Transaction pooler URL, port 6543, append ?pgbouncer=true&connection_limit=1
DIRECT_URL=                 # Session pooler URL, port 5432 (used by Prisma Migrate)

# OpenRouter (openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=CaliX

# PostHog (posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_RESET_SECRET=           # generate: openssl rand -hex 32
COMPLETION_TOKEN_SECRET=     # generate: openssl rand -hex 32
